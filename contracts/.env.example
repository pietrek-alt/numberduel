# Copy to .env and fill in. NEVER commit .env or a real private key.

# A Filecoin Calibration testnet wallet private key (0x-prefixed).
# This wallet needs tFIL for gas. Use a throwaway key, testnet only.
PRIVATE_KEY=0x...

# Calibration RPC (default is fine).
CALIBRATION_RPC=https://api.calibration.node.glif.io/rpc/v1

# USDFC token on Calibration (default is correct; override only for local tests).
USDFC_ADDRESS=0xb3042734b608a1B16e9e86B374A3f3e389B4cDf0
